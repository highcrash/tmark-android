<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TMarkClient" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme — dark background while app loads -->
    <style name="Theme.TMarkClient.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.TMarkClient</item>
    </style>
</resources>
